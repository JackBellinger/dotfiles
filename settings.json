{
    "cloudcode.updateChannel": "Insiders",
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": false,
        "scminput": false
    },
    "github.copilot.advanced": {
    },
    "telemetry.telemetryLevel": "off",
    "workbench.enableExperiments": false,
    "workbench.cloudChanges.continueOn": "off",
    "workbench.cloudChanges.autoResume": "off",
    "npm.fetchOnlinePackageInfo": false,

// === Whitespace ===
    "editor.insertSpaces": false,
    "editor.comments.insertSpace": true,
    "editor.stickyTabStops": true,
    "editor.renderWhitespace": "all",
    "editor.unicodeHighlight.nonBasicASCII": true,

// === Editor Interface ===
    "editor.wordWrapColumn": 95,
    "editor.wordWrap": "bounded",
    "editor.minimap.enabled": false,
    "editor.occurrencesHighlight": "off",
    // Tabs
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.scrollToSwitchTabs": true,
    "workbench.editor.tabCloseButton": "off",
    "workbench.editor.wrapTabs": true,
    "workbench.editor.tabSizing": "shrink",
    // Zen Mode
    "zenMode.fullScreen": false,
    "zenMode.centerLayout": false,
    "zenMode.showTabs": "none",

// === Keybinds ===
    "files.autoSave": "onWindowChange",
    "editor.autoClosingQuotes": "beforeWhitespace",
    "editor.mouseWheelZoom": true,
    "editor.dragAndDrop": false,
    "editor.emptySelectionClipboard": true,
    "workbench.settings.openDefaultKeybindings": true,
    
    // === Suggestions ===
    "editor.inlineSuggest.enabled": true,
    
    // === Themes ===
    "editor.fontFamily": "FiraCode Nerd Font",
    "editor.fontLigatures": true,
    "workbench.preferredLightColorTheme": "Default Light Modern",
    "workbench.preferredDarkColorTheme": "Solarized Dark",
    "workbench.colorTheme": "Solarized Dark",
    "workbench.colorCustomizations": {
        "[Solarized Dark]": {
            "editorWhitespace.foreground": "#00aeff18",
            "editorInfo.background": "#38a5597c",
            "editorWarning.background": "#c5cf3670",
            "editorError.background": "#ac3a1765",
            "editorError.foreground": "#520505", // squiggly line
            "editor.selectionBackground": "#e788ff7c", //Currently SELECTED text
            "editor.selectionHighlightBackground": "#ff00005b", //Same content as selection
            "editor.findMatchBackground": "#00cc44a8", //Current SEARCH MATCH
            "editor.findMatchHighlightBackground": "#ff7b00a1", //Other SEARCH MATCHES
            "numberedBookmarks.lineBackground": "#007700",
            "editorBracketMatch.border": "#2ed7ee",
        },
        "[Default Light Modern]": {
            "editorWhitespace.foreground": "#00aeff18",
            "editorInfo.background": "#38a5597c",
            "editorWarning.background": "#c5cf3670",
            "editorError.background": "#ac3a1765",
            "editorError.foreground": "#520505", // squiggly line
            "editor.selectionBackground": "#e788ff7c", //Currently SELECTED text
            "editor.selectionHighlightBackground": "#ff00005b", //Same content as selection
            "editor.findMatchBackground": "#00cc44a8", //Current SEARCH MATCH
            "editor.findMatchHighlightBackground": "#ff7b00a1", //Other SEARCH MATCHES
            "numberedBookmarks.lineBackground": "#007700"
        }
    },
    "editor.tokenColorCustomizations": {
        "[Solarized Dark]": { // This applies only when Monokai theme is active
            "textMateRules": [
                // 1. Bold Text: Remains Solarized Yellow for clear contrast with headings.
                {
                    "scope": "markup.bold.markdown",
                    "settings": {
                        "foreground": "#268bd2", // Solarized Light blue
                        "fontStyle": "bold"
                    }
                },
                //italic 	markup.italic.markdown
                // meta.paragraph.markdown
                // markup.list.unnumbered.markdown
                // text.html.markdown
                {
                    "scope": "markup.italic.markdown",
                    "settings": {
                        "foreground": "#859900", // Solarized Light Cyan
                    }
                },
                // 2. Inline Code: Solarized Cyan for distinct code snippets.
                {
                    "scope": "markup.inline.raw.string.markdown",
                    "settings": {
                        "foreground": "#2aa198" // Solarized Cyan
                    }
                },
                // 3. Links: Solarized Blue with underline to distinguish from headings.
                {
                    "scope": "markup.underline.link.markdown",
                    "settings": {
                        "foreground": "#268bd2", // Solarized Blue
                        "fontStyle": "underline"
                    }
                },
                // 4. List Item Markers: Solarized Green.
                {
                    "scope": "punctuation.definition.list.begin.markdown",
                    "settings": {
                        "foreground": "#859900" // Solarized Green
                    }
                },
                // 5. List Item Content (Text): Solarized Green.
                {
                    "scope": "markup.list.unnumbered.markdown, markup.list.ordered.markdown",
                    "settings": {
                        "foreground": "#859900" // Solarized Green
                    }
                },
                // --- Headings: Different shades of blue, smaller headers darker ---
                {
                    // H1 text and its hash punctuation
                    "scope": "heading.1.markdown entity.name.section.markdown, heading.1.markdown punctuation.definition.heading.markdown",
                    "settings": {
                        "foreground": "#b58900", // Solarized yellow (lightest for H1)
                        "fontStyle": "bold underline",
                    }
                },
                {
                    // H2 text and its hash punctuation
                    "scope": "heading.2.markdown entity.name.section.markdown, heading.2.markdown punctuation.definition.heading.markdown",
                    "settings": {
                        "foreground": "#b58900", // Custom darker yellow for H2
                        "fontStyle": "bold"
                    }
                },
                {
                    // H3 text and its hash punctuation
                    "scope": "heading.3.markdown entity.name.section.markdown, heading.3.markdown punctuation.definition.heading.markdown",
                    "settings": {
                        "foreground": "#b58900", // Lighter than previous H3, good contrast
                        "fontStyle": "bold"
                    }
                },
                {
                    // H4 text and its hash punctuation
                    "scope": "heading.4.markdown entity.name.section.markdown, heading.4.markdown punctuation.definition.heading.markdown",
                    "settings": {
                        "foreground": "#b58900", // Lighter than previous H4, good contrast
                        "fontStyle": "bold"
                    }
                },
                // H5 text and its hash punctuation
                {
                    "scope": "heading.5.markdown entity.name.section.markdown, heading.5.markdown punctuation.definition.heading.markdown",
                    "settings": {
                        "foreground": "#b58900", // Near black for H5
                        "fontStyle": "bold"
                    }
                },
                // H6 text and its hash punctuation
                {
                    "scope": "heading.6.markdown entity.name.section.markdown, heading.6.markdown punctuation.definition.heading.markdown",
                    "settings": {
                        "foreground": "#b58900", // Darkest blue for H6, very subtle
                        "fontStyle": "bold"
                    }
                }
            ]
        }
    },
    "markdown.styles": ["./solarized-dark-md-preview.css"],
    "[markdown]": {
        "files.trimTrailingWhitespace": false,
        "editor.wordWrap": "bounded",
    },
// === Rust ===
    "[rust]": {
        "editor.formatOnSave": true,
    },
    "rust-analyzer.debug.openDebugPane": true,
    "rust-analyzer.inlayHints.lifetimeElisionHints.enable": "skip_trivial",
    "rust-analyzer.interpret.tests": true,
    "rust-analyzer.restartServerOnConfigChange": true,
    "rust-analyzer.inlayHints.parameterHints.enable": true,
    "editor.parameterHints.enabled": false,
    "rust-analyzer.inlayHints.typeHints.enable": false,
    "rust-analyzer.hover.actions.gotoTypeDef.enable": false,
    "rust-analyzer.inlayHints.chainingHints.enable": false,
    "rust-analyzer.highlightRelated.references.enable": false,
    "evenBetterToml.syntax.semanticTokens": false,
    "rust-analyzer.check.command": "clippy",
    // "rust-analyzer.check.extraArgs": [
    //     "-- -W clippy::pedantic"
    // ],
// === Svelte ===
    "typescript.updateImportsOnFileMove.enabled": "always",
    "svelte.enable-ts-plugin": true,
    "prettier.htmlWhitespaceSensitivity": "strict",
    "prettier.printWidth": 120,
    "prettier.quoteProps": "consistent",
    "prettier.tabWidth": 4,
    "prettier.useTabs": true,
    "files.associations": {
        "*.sxv": "markdown",
        "*.svx": "markdown",
        "*.mdx": "markdown"
    },

    "evenBetterToml.rules": [
    ],
    "evenBetterToml.formatter.allowedBlankLines": 2,
    "evenBetterToml.formatter.columnWidth": 128,
    "evenBetterToml.schema.associations": {
    },
    "evenBetterToml.formatter.reorderKeys": true,
    "evenBetterToml.formatter.reorderArrays": true,

// === C/C++ ===
    "cmake.configureOnOpen": false,
    "editor.unicodeHighlight.allowedCharacters": {
        "─": true,
        "┴": true,
        "┬": true,
        "│": true,
        "┐": true,
        "┌": true,
        "┤": true,
        "├": true,
        "┼": true,
        "└": true,
        "┘": true
    },
    "editor.codeActionsOnSave": {

    },
    "extensions.ignoreRecommendations": true,
    "explorer.confirmDragAndDrop": false,
    "editor.inlayHints.enabled": "off",
    "editor.tabSize": 3,
    "editor.indentSize": "tabSize",
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "sqltools.highlightQuery": false,
    "sqltools.queryParams.enableReplace": true,
    "sqltools.format": {
        "reservedWordCase": "upper",
        "linesBetweenQueries": "preserve"
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "haskell.manageHLS": "PATH",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.trimAutoWhitespace": false,
    "workbench.editor.tabActionCloseVisibility": false,
    "remote.autoForwardPortsSource": "hybrid",
    "rust-analyzer.completion.snippets.custom": {
        "Arc::new": {
            "postfix": "arc",
            "body": "Arc::new(${receiver})",
            "requires": "std::sync::Arc",
            "description": "Put the expression into an `Arc`",
            "scope": "expr"
        },
        "Rc::new": {
            "postfix": "rc",
            "body": "Rc::new(${receiver})",
            "requires": "std::rc::Rc",
            "description": "Put the expression into an `Rc`",
            "scope": "expr"
        },
        "Box::pin": {
            "postfix": "pinbox",
            "body": "Box::pin(${receiver})",
            "requires": "std::boxed::Box",
            "description": "Put the expression into a pinned `Box`",
            "scope": "expr"
        },
        "Ok": {
            "postfix": "ok",
            "body": "Ok(${receiver})",
            "description": "Wrap the expression in a `Result::Ok`",
            "scope": "expr"
        },
        "Err": {
            "postfix": "err",
            "body": "Err(${receiver})",
            "description": "Wrap the expression in a `Result::Err`",
            "scope": "expr"
        },
        "Some": {
            "postfix": "some",
            "body": "Some(${receiver})",
            "description": "Wrap the expression in an `Option::Some`",
            "scope": "expr"
        }
    },
    "extensions.autoUpdate": "onlyEnabledExtensions",
    "C_Cpp.intelliSenseEngine": "disabled",
    "silabs.loggingFolderPath": "/tmp/silabs_extension",
    "geminicodeassist.updateChannel": "Insiders",
    "diffEditor.codeLens": true,
    "geminicodeassist.enableTelemetry": false,
    "geminicodeassist.inlineSuggestions.enableAuto": false,
    "diffEditor.experimental.showMoves": true,
    "workbench.sideBar.location": "right",
    "cSpell.userWords": [
        "automations",
        "Bellinger",
        "blockquotes",
        "Falkor",
        "frontmatter",
        "frontmatters",
        "Logseq",
        "pagespeed",
        "Refactorable",
        "reqs",
        "Taskie"
    ],
    "chat.editor.wordWrap": "on",
    "geminicodeassist.project": "gen-lang-client-0700379828",
    "geminicodeassist.chat.automaticScrolling": false,
    "editor.fontWeight": "100",

    //"settings.cycle": [
